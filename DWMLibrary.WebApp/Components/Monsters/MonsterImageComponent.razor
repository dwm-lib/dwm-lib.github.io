<div class=@(css)>
    @if (!IsPlaceholder)
    {
        <img class="img-fluid" src=@(url) draggable="false" alt=@(alt) width=@(wh) height=@(wh) />
    }
    else
    {
        <svg class="img-fluid placeholder placeholder-glow" role="img" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" width=@(wh) height=@(wh)>
            <title>Placeholder</title>
            <rect class="placeholder placeholder-glow" width="100%" height="100%" fill="#868e96"></rect>
        </svg>
    }
</div>