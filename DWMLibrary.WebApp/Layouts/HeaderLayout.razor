@inherits LayoutComponentBase

<nav class="navbar navbar-expand-md bg-primary bg-gradient flex-nowrap py-2">
    <div class="container">
        <NavLink class="navbar-brand p-0" href="" Match="NavLinkMatch.All">
            <span class="d-inline-flex flex-row align-items-center align-content-center w-100 h-100">
                <img class="img-fluid pt-1" src="/img/2x/wonderegg-2x.png" draggable="false" alt="Logo" width="32" height="36" />
                <b class="d-block p-0 ms-3 text-center" style="font-size: 1.5rem;">WonderEgg</b>
            </span>
        </NavLink>
        <div class="navbar-collapse collapse">
            <ul class="navbar-nav me-auto">
                @foreach (var link in NavigationLinks)
                {
                    <li class="nav-item mx-0 mx-md-1 mt-2 mt-md-0">
                        <NavLink class="nav-link p-2" href=@(link.Value)>
                            @(link.Key)
                        </NavLink>
                    </li>
                }
            </ul>
        </div>
        <button class="navbar-toggler border-0 ms-auto" type="button" data-bs-toggle="offcanvas" data-bs-target=".offcanvas">
            <i class="bi bi-chevron-down"></i>
        </button>
    </div>
</nav>
<nav class="offcanvas offcanvas-top bg-primary bg-gradient flex-nowrap py-2" data-bs-scroll="true" data-bs-backdrop="true" tabindex="-1">
    <div class="container">
        <NavLink class="d-flex flex-row p-0 mb-2" href="" Match="NavLinkMatch.All">
            <span class="d-inline-flex flex-row align-items-center align-content-center w-100 h-100" data-bs-dismiss="offcanvas" data-bs-target=".offcanvas">
                <img class="img-fluid pt-1" src="/img/2x/wonderegg-2x.png" draggable="false" alt="Logo" width="32" height="36" />
                <b class="d-block p-0 ms-3 text-center" style="font-size: 1.5rem;">WonderEgg</b>
            </span>
        </NavLink>
        <ul class="navbar-nav me-auto">
            @foreach (var link in NavigationLinks)
            {
                <li class="nav-item mx-0 mx-md-1 mt-2 mt-md-0">
                    <NavLink class="nav-link p-2" href=@(link.Value)>
                        <span class="d-block w-100 h-100" data-bs-dismiss="offcanvas" data-bs-target=".offcanvas">
                            @(link.Key)
                        </span>
                    </NavLink>
                </li>
            }
        </ul>
        <button class="navbar-toggler border-0 w-100 mt-2" type="button" data-bs-dismiss="offcanvas" data-bs-target=".offcanvas">
            <i class="bi bi-chevron-up text-end"></i>
        </button>
    </div>
</nav>
