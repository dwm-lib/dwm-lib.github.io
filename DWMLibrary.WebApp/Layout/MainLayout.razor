@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<header class="fixed-top">
    <CascadingValue Value="@collapseNavMenu">
        <NavigationBar OnClickCallback=@HandleChildClicks />
        <BreadcrumbBar Links="@breadcrumbLinks" OnClickCallback=@HandleChildClicks />
    </CascadingValue>
</header>
@if (!collapseNavMenu)
{
    <aside class="overlay" @onclick="HandleFadeClick" />
}
<article class="flex-grow-1">
    <ErrorBoundary @ref="errorBoundary">
        <ChildContent>
            @Body
        </ChildContent>
        <ErrorContent>
            @* <NotFoundPage /> *@
            
        </ErrorContent>
    </ErrorBoundary>
</article>
<footer class="mt-auto">
    <StatisticsBar />
</footer>
