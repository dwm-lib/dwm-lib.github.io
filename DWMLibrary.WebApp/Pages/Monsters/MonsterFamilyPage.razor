@page "/monster/family/{familyName}"
@inject IDataService DataService

<PageTitle>DWM Library - Family - @(Uri.UnescapeDataString(familyName))</PageTitle>

@if (dataLoaded)
{
    <div class="container">
        <div class="row">
            <h1 class="col-12">The @(Uri.UnescapeDataString(familyName)) Family</h1>
        </div>
        <div class="row mb-3">
            <section>
                <MonsterCardGridComponent monsters=@(monsters!.OrderBy(monster => monster.Id).ToArray()) />
            </section>
        </div>
        <div class="row">
            <div class="col-lg-6">
                <section>
                    <h2>Growths</h2>
                    <MonsterGrowthsComponent monsters=@(monsters) includeNames=true />
                </section>
            </div>
            <div class="col-lg-6">
                <section>
                    <MonsterBreedsComponent breeds=@(breeds) includeTargets=true />
                </section>
            </div>
        </div>
    </div>
}

@if (notFound)
{
    <NotFoundComponent />
}
