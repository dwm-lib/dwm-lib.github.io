@page "/monster"
@page "/monster/size"
@page "/monster/rarity"
@inject IDataService DataService
@inject NavigationManager NavigationManager

<PageTitle>WonderEgg - Monsters</PageTitle>

<div class="container">
    <div class="row">
        <h1 class="col-12">Monsters</h1>
    </div>
    <ul class="nav nav-pills justify-content-center" id="pills-tab" role="tablist">
        <li class="nav-item mx-1" role="presentation">
            <NavLink class="nav-link" href="monster" Match="NavLinkMatch.All">
                All
            </NavLink>
        </li>
        <li class="nav-item mx-1" role="presentation">
            <NavLink class="nav-link" href="/monster/size">
                By Size
            </NavLink>
        </li>
        <li class="nav-item mx-1" role="presentation">
            <NavLink class="nav-link" href="/monster/rarity">
                By Rarity
            </NavLink>
        </li>
    </ul>
    <hr class="mb-3" />
    <div class="tab-content">
        <div class="tab-pane fade @(IsShowActive(Tabs.ALL))" role="tabpanel">
            <div class="row mb-3">
                <section>
                    <MonsterCardGridComponent monsters=@(monsters?.OrderBy(monster => monster.Name)?.ToArray()) />
                </section>
            </div>
        </div>
        <div class="tab-pane fade @(IsShowActive(Tabs.SIZE))" role="tabpanel">
            @foreach (var size in Enum.GetValues<MonsterSize>())
            {
                <div class="row">
                    <HeaderLinkComponent href=@($"/monster/size/{Uri.EscapeDataString(size.ToString())}") text=@($"Size {size.ToJsonString()}") />
                </div>
                <div class="row mb-3">
                    <section>
                        <MonsterCardGridComponent monsters=@(monsters?.Where(monster => monster.Size == size)?.OrderBy(monster => monster.Id)?.ToArray()) />
                    </section>
                </div>
            }
        </div>
        <div class="tab-pane fade @(IsShowActive(Tabs.RARITY))" role="tabpanel">
            @foreach (var rarity in Enum.GetValues<MonsterRarity>())
            {
                <div class="row">
                    <HeaderLinkComponent href=@($"/monster/rarity/{rarity}") text=@(rarity.ToJsonString()) />
                </div>
                <div class="row mb-3">
                    <section>
                        <MonsterCardGridComponent monsters=@(monsters?.Where(monster => monster.Rarity == rarity)?.OrderBy(monster => monster.Id)?.ToArray()) />
                    </section>
                </div>
            }
        </div>
    </div>
</div>
