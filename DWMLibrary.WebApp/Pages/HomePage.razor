@page "/"
@inject IDataService DataService

<PageTitle>DWM Library - Home</PageTitle>

@if (dataLoaded)
{
    <div class="container">
        <div class="row">
            <h1 class="col-12">DWM Library</h1>
            <div id="Intro" class="col-12">
                <p>
                    Welcome to the breed database for Dragon Warrior: Monsters 2.
                    <br />
                    Click any link to start.
                </p>
            </div>
        </div>
        <hr class="mb-3" />
        <section>
            <div class="row">
                <HeaderLinkComponent href=@($"/monster") text=@($"Monsters") h1=true />
            </div>
            <div class="row">
                <HeaderLinkComponent href=@($"/monster/family") text=@($"Families") />
            </div>
            <div class="row mb-3">
                <section>
                    <CardGridComponent href=@($"/monster/family") categories=@(typeof(MonsterFamily).GetJsonTuples()) />
                </section>
            </div>
            <div class="row">
                <HeaderLinkComponent href=@($"/monster/location") text=@($"Locations") />
            </div>
            <div class="row mb-3">
                <section>
                    <CardGridComponent href=@($"/monster/location") categories=@(typeof(MonsterLocationType).GetJsonTuples()) />
                </section>
            </div>
            <div class="row">
                <HeaderLinkComponent href=@($"/monster/size") text=@($"Sizes") />
            </div>
            <div class="row mb-3">
                <section>
                    <CardGridComponent href=@($"/monster/size") categories=@(typeof(MonsterSize).GetJsonTuples()) />
                </section>
            </div>
            <div class="row">
                <HeaderLinkComponent href=@($"/monster/rarity") text=@($"Rarities") />
            </div>
            <div class="row mb-3">
                <section>
                    <CardGridComponent href=@($"/monster/rarity") categories=@(typeof(MonsterRarity).GetJsonTuples()) />
                </section>
            </div>
        </section>
        <hr class="mb-3" />
        <section>
            <div class="row">
                <HeaderLinkComponent href=@($"/skill") text=@($"Skills") h1=true />
            </div>
            <div class="row">
                <HeaderLinkComponent href=@($"/skill/type") text=@($"Types") />
            </div>
            <div class="row mb-3">
                <section>
                    <CardGridComponent href=@($"/skill/type") categories=@(typeof(SkillType).GetJsonTuples()) />
                </section>
            </div>
            <div class="row">
                <HeaderLinkComponent href=@($"/skill/category") text=@($"Categories") />
            </div>
            <div class="row mb-3">
                <section>
                    <CardGridComponent href=@($"/skill/category") categories=@(typeof(SkillCategory).GetJsonTuples()) />
                </section>
            </div>
            <div class="row">
                <HeaderLinkComponent href=@($"/skill/attribute") text=@($"Attributes") />
            </div>
            <div class="row mb-3">
                <section>
                    <CardGridComponent href=@($"/skill/attribute") categories=@(typeof(SkillAttribute).GetJsonTuples()) />
                </section>
            </div>
        </section>
        <hr class="mb-3" />
        <div class="row">
            <div class="col-12 text-center">
                <span style="font-size: .9rem; font-weight: lighter; font-style: italic; color: var(--bs-tertiary-color);">
                    Monsters: @(monsters!.Length) &nbsp;&nbsp;|&nbsp;&nbsp; Breeds: @(breeds!.Length) &nbsp;&nbsp;|&nbsp;&nbsp; Skills: @(skills!.Length)
                </span>
            </div>
        </div>
    </div>
}

@if (notFound)
{
    <NotFoundComponent />
}
